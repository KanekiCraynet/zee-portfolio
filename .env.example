# Contact Form (Resend)
RESEND_API_KEY=
CONTACT_EMAIL=

# Keystatic CMS — GitHub mode (production only)
# Create OAuth app at: https://github.com/settings/applications/new
KEYSTATIC_GITHUB_CLIENT_ID=
KEYSTATIC_GITHUB_CLIENT_SECRET=
KEYSTATIC_SECRET=

# Keystatic — Repository info (used in keystatic.config.ts)
NEXT_PUBLIC_GITHUB_OWNER=KanekiCraynet
NEXT_PUBLIC_GITHUB_REPO=zee-portfolio

# Sentry (optional — error tracking; no-ops if unset)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
